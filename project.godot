; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SerpentsTrial"
run/main_scene="res://Scenes/UI/Intro.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://Assets/Sprites/game_iconV2.png"

[audio]

buses/default_bus_layout="res://Assets/Other/default_bus_layout.tres"

[autoload]

Signal_Bus="*res://Scripts/Game/signal_bus.gd"
Save_System="*res://Scenes/Infrastructure/Save_System.tscn"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="res://Assets/Sprites/UI/UI_mouse_cursorV2_20x25.png"

[file_customization]

folder_colors={
"res://Assets/": "pink",
"res://Scenes/": "red",
"res://Scripts/": "teal"
}

[global_group]

Player=""
Enemies=""
UI=""
UI_Brudi=""

